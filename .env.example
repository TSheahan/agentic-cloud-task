# AWS credentials for cloud provisioning
# Copy to .env and populate with real values
AWS_ACCESS_KEY_ID_CLOUD=
AWS_SECRET_ACCESS_KEY_CLOUD=
AWS_DEFAULT_REGION=ap-southeast-2

# Optional: default sts:AssumeRole target for tools/_env.py (Batch, ECR, broad EC2, …).
# Example: arn:aws:iam::123456789012:role/agentic-cloud-task-orchestrator-role
# AGENTIC_ORCHESTRATOR_ROLE_ARN=
