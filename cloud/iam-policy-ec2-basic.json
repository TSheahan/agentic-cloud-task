{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "Discover",
            "Effect": "Allow",
            "Action": "ec2:Describe*",
            "Resource": "*"
        },
        {
            "Sid": "DiscoverTaggedResources",
            "Effect": "Allow",
            "Action": "tag:GetResources",
            "Resource": "*"
        },
        {
            "Sid": "LaunchInstancesCreatedResources",
            "Effect": "Allow",
            "Action": "ec2:RunInstances",
            "Resource": [
                "arn:aws:ec2:*:*:instance/*",
                "arn:aws:ec2:*:*:volume/*",
                "arn:aws:ec2:*:*:network-interface/*"
            ],
            "Condition": {
                "StringEquals": {
                    "aws:RequestTag/Project": "agentic-cloud-task"
                }
            }
        },
        {
            "Sid": "LaunchInstancesReferencedResources",
            "Effect": "Allow",
            "Action": "ec2:RunInstances",
            "Resource": [
                "arn:aws:ec2:*::image/*",
                "arn:aws:ec2:*:*:key-pair/*",
                "arn:aws:ec2:*:*:security-group/*",
                "arn:aws:ec2:*:*:subnet/*"
            ]
        },
        {
            "Sid": "ManageProjectInstances",
            "Effect": "Allow",
            "Action": [
                "ec2:StopInstances",
                "ec2:StartInstances",
                "ec2:TerminateInstances"
            ],
            "Resource": "arn:aws:ec2:*:*:instance/*",
            "Condition": {
                "StringEquals": {
                    "ec2:ResourceTag/Project": "agentic-cloud-task"
                }
            }
        },
        {
            "Sid": "ModifyProjectVolumes",
            "Effect": "Allow",
            "Action": "ec2:ModifyVolume",
            "Resource": "arn:aws:ec2:*:*:volume/*",
            "Condition": {
                "StringEquals": {
                    "ec2:ResourceTag/Project": "agentic-cloud-task"
                }
            }
        },
        {
            "Sid": "CreateAMIFromProjectInstances",
            "Effect": "Allow",
            "Action": "ec2:CreateImage",
            "Resource": "arn:aws:ec2:*:*:instance/*",
            "Condition": {
                "StringEquals": {
                    "ec2:ResourceTag/Project": "agentic-cloud-task"
                }
            }
        },
        {
            "Sid": "CreateAMIOutputResources",
            "Effect": "Allow",
            "Action": [
                "ec2:CreateImage",
                "ec2:RegisterImage",
                "ec2:CreateSnapshot"
            ],
            "Resource": [
                "arn:aws:ec2:*::image/*",
                "arn:aws:ec2:*::snapshot/*"
            ],
            "Condition": {
                "StringEquals": {
                    "aws:RequestTag/Project": "agentic-cloud-task"
                }
            }
        },
        {
            "Sid": "CleanupProjectAMIs",
            "Effect": "Allow",
            "Action": [
                "ec2:DeregisterImage",
                "ec2:DeleteSnapshot"
            ],
            "Resource": "*",
            "Condition": {
                "StringEquals": {
                    "ec2:ResourceTag/Project": "agentic-cloud-task"
                }
            }
        },
        {
            "Sid": "CreateProjectSecurityGroups",
            "Effect": "Allow",
            "Action": "ec2:CreateSecurityGroup",
            "Resource": "arn:aws:ec2:*:*:security-group/*",
            "Condition": {
                "StringEquals": {
                    "aws:RequestTag/Project": "agentic-cloud-task"
                }
            }
        },
        {
            "Sid": "CreateSecurityGroupInVPC",
            "Effect": "Allow",
            "Action": "ec2:CreateSecurityGroup",
            "Resource": "arn:aws:ec2:*:*:vpc/*"
        },
        {
            "Sid": "ManageProjectSecurityGroups",
            "Effect": "Allow",
            "Action": [
                "ec2:DeleteSecurityGroup",
                "ec2:AuthorizeSecurityGroupIngress",
                "ec2:AuthorizeSecurityGroupEgress",
                "ec2:RevokeSecurityGroupIngress",
                "ec2:RevokeSecurityGroupEgress"
            ],
            "Resource": "arn:aws:ec2:*:*:security-group/*",
            "Condition": {
                "StringEquals": {
                    "ec2:ResourceTag/Project": "agentic-cloud-task"
                }
            }
        },
        {
            "Sid": "AllocateProjectElasticIPs",
            "Effect": "Allow",
            "Action": "ec2:AllocateAddress",
            "Resource": "*",
            "Condition": {
                "StringEquals": {
                    "aws:RequestTag/Project": "agentic-cloud-task"
                }
            }
        },
        {
            "Sid": "ManageProjectElasticIPs",
            "Effect": "Allow",
            "Action": [
                "ec2:AssociateAddress",
                "ec2:DisassociateAddress",
                "ec2:ReleaseAddress"
            ],
            "Resource": "*",
            "Condition": {
                "StringEquals": {
                    "ec2:ResourceTag/Project": "agentic-cloud-task"
                }
            }
        },
        {
            "Sid": "CreateProjectKeyPairs",
            "Effect": "Allow",
            "Action": [
                "ec2:CreateKeyPair",
                "ec2:ImportKeyPair"
            ],
            "Resource": "arn:aws:ec2:*:*:key-pair/*",
            "Condition": {
                "StringEquals": {
                    "aws:RequestTag/Project": "agentic-cloud-task"
                }
            }
        },
        {
            "Sid": "DeleteProjectKeyPairs",
            "Effect": "Allow",
            "Action": "ec2:DeleteKeyPair",
            "Resource": "arn:aws:ec2:*:*:key-pair/*",
            "Condition": {
                "StringEquals": {
                    "ec2:ResourceTag/Project": "agentic-cloud-task"
                }
            }
        },
        {
            "Sid": "TagProjectResources",
            "Effect": "Allow",
            "Action": "ec2:CreateTags",
            "Resource": "*",
            "Condition": {
                "StringEquals": {
                    "aws:RequestTag/Project": "agentic-cloud-task"
                }
            }
        },
        {
            "Sid": "TagAtLaunch",
            "Effect": "Allow",
            "Action": "ec2:CreateTags",
            "Resource": "*",
            "Condition": {
                "StringEquals": {
                    "ec2:CreateAction": [
                        "RunInstances",
                        "CreateSecurityGroup",
                        "CreateImage",
                        "CreateSnapshot",
                        "AllocateAddress",
                        "CreateKeyPair",
                        "ImportKeyPair"
                    ]
                }
            }
        },
        {
            "Sid": "DebugProjectInstances",
            "Effect": "Allow",
            "Action": "ec2:GetConsoleOutput",
            "Resource": "arn:aws:ec2:*:*:instance/*",
            "Condition": {
                "StringEquals": {
                    "ec2:ResourceTag/Project": "agentic-cloud-task"
                }
            }
        },
        {
            "Sid": "Observability",
            "Effect": "Allow",
            "Action": [
                "logs:GetLogEvents",
                "logs:FilterLogEvents",
                "logs:DescribeLogGroups",
                "logs:DescribeLogStreams",
                "cloudwatch:GetMetricData",
                "cloudwatch:ListMetrics"
            ],
            "Resource": "*"
        },
        {
            "Sid": "CostGovernance",
            "Effect": "Allow",
            "Action": [
                "ce:GetCostAndUsage",
                "ce:GetCostForecast",
                "budgets:ViewBudget"
            ],
            "Resource": "*"
        },
        {
            "Sid": "SpotServiceRole",
            "Effect": "Allow",
            "Action": "iam:CreateServiceLinkedRole",
            "Resource": "arn:aws:iam::*:role/aws-service-role/spot.amazonaws.com/*",
            "Condition": {
                "StringEquals": {
                    "iam:AWSServiceName": "spot.amazonaws.com"
                }
            }
        }
    ]
}
